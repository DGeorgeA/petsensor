# SenseMyPet — build-time configuration (all values here are PUBLIC tier).
# Copy to .env.local for local development. NEVER put service_role keys,
# database passwords, or any payment SECRET keys in this file or anywhere
# in the frontend — RLS and the Supabase Edge Function are the security boundary.

# ── Supabase (public) ──────────────────────────────────────────────────────────
# OPTIONAL overrides — src/lib/supabase.ts already bakes in the project URL and
# anon PUBLIC key (safe to ship; RLS is the security boundary). Set these only
# to point a build at a DIFFERENT project. Reference audio bucket: audio_sense.
# VITE_SUPABASE_URL=https://tcmcetpfdgpujayjbzrs.supabase.co
# VITE_SUPABASE_ANON_KEY=

# ── Payments (public config only — P13/P14) ───────────────────────────────────
# enabled + environment control whether any checkout UI exists at all (P16).
# VITE_PAYMENTS_ENABLED=true
# VITE_PAYMENTS_ENV=test            # off | test | live
# VITE_PAYMENTS_PROVIDER=razorpay   # razorpay | paypal | google_pay | none
# VITE_PAYMENTS_CURRENCY=INR
# VITE_PAYMENTS_PUBLIC_CLIENT_ID=   # publishable id only (rzp_test_…, PayPal client-id)
# VITE_PAYMENTS_FEATURES=vetPlus    # csv: vetPlus,subscription,oneTime,premiumScan
